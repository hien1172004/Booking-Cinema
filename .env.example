# ==============================================================================
# CINEMA BOOKING SYSTEM - ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# Hướng dẫn: Sao chép tệp này thành .env và điền các giá trị thực tế của bạn.
# KHÔNG ĐƯỢC commit tệp .env thật lên GitHub.

# ------------------------------------------------------------------------------
# 1. Cấu Hình Ứng Dụng (Application)
# ------------------------------------------------------------------------------
APP_PORT=8081
# Sử dụng 'prod' khi deploy lên Railway/Render, 'dev' khi chạy máy cá nhân
SPRING_PROFILES_ACTIVE=dev
# URL công khai của App (Dùng cho VNPay Callback & Swagger HTTPS)
# VD: https://your-app.up.railway.app
PROD_URL=http://localhost:8081

# ------------------------------------------------------------------------------
# 2. Cơ Sở Dữ Liệu (MySQL)
# ------------------------------------------------------------------------------
# Local: jdbc:mysql://localhost:3307/cinema_db
# Cloud: jdbc:mysql://host:port/defaultdb?ssl-mode=REQUIRED
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3307/cinema_db
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_password_here

# ------------------------------------------------------------------------------
# 3. Bộ Nhớ Đệm & Rate Limit (Redis / Valkey)
# ------------------------------------------------------------------------------
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
# Để trống nếu không dùng mật khẩu ở local
SPRING_REDIS_PASSWORD=

# ------------------------------------------------------------------------------
# 4. Bảo Mật & Xác Thực (Security - JWT)
# ------------------------------------------------------------------------------
# Generate chuỗi Base64 dài ít nhất 64 ký tự
JWT_SIGNER_KEY=your_very_long_secret_key_generate_at_least_64_chars_here

# ------------------------------------------------------------------------------
# 5. Lưu Trữ Hình Ảnh (Cloudinary)
# Lấy tại: https://cloudinary.com/console
# ------------------------------------------------------------------------------
CLOUD_NAME=your_cloud_name
CLOUD_API_KEY=your_api_key
CLOUD_API_SECRET=your_api_secret

# ------------------------------------------------------------------------------
# 6. Dịch Vụ Email (Gmail SMTP)
# Tạo App Password tại: https://myaccount.google.com/apppasswords
# ------------------------------------------------------------------------------
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_16_chars

# ------------------------------------------------------------------------------
# 7. Thanh Toán VNPay
# Đăng ký lấy Key test tại: https://sandbox.vnpayment.vn/paymentv2/Init/RegisTest.html
# ------------------------------------------------------------------------------
TMN_CODE=your_vnpay_tmn_code
TMN_KEY=your_vnpay_hash_secret_key

# ------------------------------------------------------------------------------
# 8. Trí Tuệ Nhân Tạo (Google Gemini AI)
# Lấy API Key miễn phí tại: https://aistudio.google.com/apikey
# ------------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com
APP_AI_ENABLED=true
CHAT_MEMORY_TTL=PT24H

# ------------------------------------------------------------------------------
# 9. Ngrok (Chỉ dùng khi test IPN VNPay ở local)
# ------------------------------------------------------------------------------
NGROK_URL=https://your-ngrok-subdomain.ngrok-free.app